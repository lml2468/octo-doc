# octo-doc configuration — all knobs are env vars (12-factor). Copy to .env.
# Every value below is a default; uncomment to override.

# ── Network ──────────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
# Public base URL — used to build absolute /d/<slug>/v/<n> links in API
# responses. Set to your real origin in production (e.g. https://d.example.com).
# BASE_URL=https://d.example.com

# ── Storage (PostgreSQL + S3-compatible — both required) ─────────────────────
# PostgreSQL connection string for metadata, comments, sessions, and tokens.
DATABASE_URL=postgres://octo:octo@localhost:5432/octodoc
# Max connections PER POOL. octo-doc keeps two pools — one for queries, one for
# the per-slug advisory locks (cross-instance serialization) — so total server
# connections is up to 2×PG_POOL_MAX. Size your Postgres max_connections to match.
# PG_POOL_MAX=10

# S3 / MinIO / R2 for immutable HTML blobs.
S3_BUCKET=octo-doc
S3_REGION=us-east-1
# S3_ENDPOINT=http://localhost:9000        # MinIO/R2 endpoint; omit for AWS S3
# S3_FORCE_PATH_STYLE=1                     # required for MinIO
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# ── Write auth ───────────────────────────────────────────────────────────────
# If set, this is THE Bearer token for all write endpoints. If unset, the first
# token is minted once via GET /v1/admin/bootstrap (then bootstrap 409s).
# WRITE_TOKEN=
ALLOW_BOOTSTRAP=true

# ── Read privacy ─────────────────────────────────────────────────────────────
# Documents are PRIVATE BY DEFAULT: only the write-token holder (author) can read
# a doc. To let others read + comment, mint a per-doc share code (`octo share
# <slug>`, or the Share button) and hand out the resulting ?code= link. There is
# no global public/private switch — privacy is per-document. See docs/AUTH.md.

# ── Security headers ─────────────────────────────────────────────────────────
# Who may iframe rendered docs. 'none' blocks all embedding (anti-clickjacking).
# To embed in a parent panel: FRAME_ANCESTORS="'self' https://panel.example.com"
FRAME_ANCESTORS='none'
# Set false ONLY for plain-HTTP local dev (cookies need Secure behind TLS).
COOKIE_SECURE=true

# ── Limits / quotas ──────────────────────────────────────────────────────────
MAX_HTML_BYTES=5242880          # 5 MiB per document
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60               # writes per window per (token+IP); 0 disables
# Honor X-Forwarded-For / X-Real-IP for the client IP (rate limiting). Enable
# ONLY behind a trusted reverse proxy — otherwise clients can spoof these to
# evade limits. When false, the socket peer (RemoteAddr) is used.
TRUST_PROXY_HEADERS=false
# Comma-separated allowlist of origins permitted on mutating /v1 routes (CORS).
# Empty = no Access-Control-Allow-Origin on writes (same-origin only). Reads/CLI
# are always allowed cross-origin. e.g. CORS_ORIGINS=https://app.example.com
# CORS_ORIGINS=

# ── Identity (anonymous for now) ─────────────────────────────────────────────
# Comments are anonymous: there is no built-in login provider. A future Octo
# unified login will populate viewer sessions; the OWNER below then designates
# which signed-in login sees the /me catalog (no effect while anonymous).
# OWNER=your-login

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info                  # debug|info|warn|error|silent

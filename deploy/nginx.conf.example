# Reference nginx config for octo-doc (alternative to the default Caddy).
# TLS termination assumed handled by certbot / your CA. Adjust server_name +
# cert paths. Forwards the real client IP so the app rate limiter keys correctly.

upstream octo_doc {
    server 127.0.0.1:8080;
    keepalive 16;
}

server {
    listen 80;
    server_name docs.example.com;
    # certbot will rewrite this to listen 443 ssl; redirect 80 -> 443.
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name docs.example.com;

    ssl_certificate     /etc/letsencrypt/live/docs.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/docs.example.com/privkey.pem;

    # Single interactive HTML docs can be a few MB; allow up to the app cap.
    client_max_body_size 8m;
    gzip on;
    gzip_types text/html application/javascript application/json text/css;

    location / {
        proxy_pass http://octo_doc;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

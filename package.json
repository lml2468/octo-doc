{
  "name": "octo-doc",
  "version": "1.0.0",
  "type": "module",
  "description": "Self-hosted, prompt-native interactive HTML documents — slug + monotonic version + immutable HTML, with text/artifact-anchored commenting. A Cloudflare-free reimplementation of tdoc.",
  "license": "MIT",
  "homepage": "https://github.com/lml2468/octo-doc",
  "repository": {
    "type": "git",
    "url": "https://github.com/lml2468/octo-doc"
  },
  "bin": {
    "octo-doc": "./dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "migrate": "tsx src/storage/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run test/e2e",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "bench": "tsx bench/run.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "pino": "^9.5.0"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^3.2.6",
    "autocannon": "^8.0.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^6",
    "vitest": "^3.2.6"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
